rule FILTER_VCF_SNVS:
    input:
        CHROM_VCF="/rds/project/rds-p67MZilb2eQ/projects/VGP/heterozygosity/HGDP_analyses/hgdp_wgs.20190516.full.chr{CHROM}.vcf.gz"
    output:
