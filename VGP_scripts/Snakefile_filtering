    resources:
        mem_mb=20000, 
        runtime="6h"
    params:
        SPEC_NAME=SPEC_NAME
    shell:
        """
        mkdir -p ../groups/{CLADE}/{FULL_SPEC_NAME}/heterozygosity
        ALNchain -o../groups/{CLADE}/{FULL_SPEC_NAME}/heterozygosity/{ALN_NAME}.chain.1aln -G -S -R../groups/{CLADE}/{FULL_SPEC_NAME}/heterozygosity/{params.SPEC_NAME}_chroms.txt {input}
